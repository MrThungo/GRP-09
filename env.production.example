SECRET_KEY=replace-with-a-long-random-production-secret
DATABASE_URL=mssql+pyodbc://USERNAME:PASSWORD@SERVER/NMBHLab?driver=ODBC+Driver+18+for+SQL+Server&TrustServerCertificate=yes
APP_BASE_URL=https://your-iis-site-url.example
ENABLE_QUICK_LOGIN=false
SUPER_ADMIN_EMAIL=superadmin@nmbhlab.com

SESSION_COOKIE_SECURE=true
SESSION_IDLE_TIMEOUT_MINUTES=20
PREFERRED_URL_SCHEME=https
ENABLE_HSTS=true
LIVE_SNAPSHOT_CACHE_SECONDS=3
TRUST_PROXY_HEADERS=true
PROXY_FIX_X_FOR=1
PROXY_FIX_X_PROTO=1
PROXY_FIX_X_HOST=1
PROXY_FIX_X_PREFIX=1

# Required for reliable live video when patients and doctors are on different
# networks. Use a real TURN service for PythonAnywhere deployments.
WEBRTC_STUN_URLS=stun:stun.l.google.com:19302
WEBRTC_TURN_URLS=
WEBRTC_TURN_USERNAME=
WEBRTC_TURN_CREDENTIAL=
WEBRTC_FORCE_RELAY=false

# Optional seeded account passwords for local testing only.
# Leave blank in production unless you explicitly enable SEED_DEFAULT_USERS.
DEFAULT_USER_PASSWORD=
DEFAULT_SUPER_ADMIN_PASSWORD=
DEFAULT_ADMIN_PASSWORD=
DEFAULT_DOCTOR_PASSWORD=
DEFAULT_TECHNICIAN_PASSWORD=
DEFAULT_MANAGER_PASSWORD=
DEFAULT_PATIENT_PASSWORD=

MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_DEFAULT_SENDER=no-reply@medilabconnect.local

GREENAPI_ENABLED=false
GREENAPI_API_URL=https://api.green-api.com
GREENAPI_ID_INSTANCE=
GREENAPI_API_TOKEN_INSTANCE=
GREENAPI_DEFAULT_COUNTRY_CODE=27
GREENAPI_TIMEOUT_SECONDS=10
GREENAPI_INCLUDE_TEMP_PASSWORD=false

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_CONVERSATIONS_SERVICE_SID=
TWILIO_BOT_IDENTITY=nmb-hlab-bot
TWILIO_CONVERSATIONS_API_BASE=https://conversations.twilio.com/v1
TWILIO_CONVERSATIONS_SDK_URL=https://sdk.twilio.com/js/conversations/v2.6/twilio-conversations.min.js
TWILIO_WEBHOOK_PUBLIC_URL=
TWILIO_CHATBOT_TIMEOUT_SECONDS=10
TWILIO_VALIDATE_REQUESTS=true

# Optional local/private LLM intent router for the portal assistant.
# Keep disabled on hosted deployments unless a private model endpoint is reachable.
LOCAL_LLM_ENABLED=false
LOCAL_LLM_API_URL=
LOCAL_LLM_PROVIDER=auto
LOCAL_LLM_MODEL=llama3.1:8b
LOCAL_LLM_TIMEOUT_SECONDS=1.8
LOCAL_LLM_FAILURE_COOLDOWN_SECONDS=20

# Saved online consultation video retention.
CONSULTATION_RECORDING_RETENTION_DAYS=30
CONSULTATION_RECORDING_EXPIRY_WARNING_DAYS=7
CONSULTATION_RECORDING_CLEANUP_INTERVAL_SECONDS=3600
